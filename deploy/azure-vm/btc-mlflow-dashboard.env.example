# Copy this file to /etc/default/btc-mlflow-dashboard on the VM and adjust values.

APP_HOME=/opt/btc-mlflow-dashboard
PYTHON_BIN=/opt/btc-mlflow-dashboard/.venv/bin/python

API_HOST=127.0.0.1
API_PORT=8000
GUNICORN_WORKERS=3
LOG_LEVEL=info
DJANGO_SETTINGS_MODULE=btc_dashboard.settings
DJANGO_SECRET_KEY=replace-this-with-a-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=your-domain.example,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.example
DJANGO_DB_PATH=/opt/btc-mlflow-dashboard/db.sqlite3
DJANGO_STATIC_ROOT=/opt/btc-mlflow-dashboard/staticfiles
DJANGO_TIME_ZONE=UTC

BTC_DATASET_PATH=/opt/btc-mlflow-dashboard/btc_usd_2y_1h_data.csv
BTC_MODEL_PATH=/opt/btc-mlflow-dashboard/models/linear_regression_model.joblib
BTC_ARIMA_MODEL_PATH=/opt/btc-mlflow-dashboard/models/arima_model.pkl

MLFLOW_TRACKING_URI=sqlite:////opt/btc-mlflow-dashboard/mlflow.db
MLFLOW_EXPERIMENT_NAME=btc_forecasting_pipeline

REACT_APP_DIR=/opt/btc-mlflow-dashboard/frontend
REACT_BUILD_DIR=/opt/btc-mlflow-dashboard/frontend/dist
VITE_API_BASE_URL=/api

# Bootstrap controls used by deploy/azure-vm/bootstrap_data_and_models.sh
FORCE_REFRESH_DATA=0
FORCE_RETRAIN_MODELS=0

# Optional behavior used by deploy/azure-vm/redeploy.sh
RUN_BOOTSTRAP_ON_REDEPLOY=0
